{
  "_schema": {
    "description": "Campaign Configuration - defines a single campaign including assigned products and UGC gallery",
    "version": "1.0.0",
    "managed_by": "Admin API (/api/admin/campaigns)",
    "field_constraints": {
      "campaign_id": {
        "type": "string",
        "format": "UUID v4",
        "required": true,
        "description": "Unique campaign identifier"
      },
      "campaign_name": {
        "type": "string",
        "required": true,
        "max_length": 200,
        "description": "Human-readable campaign name"
      },
      "product_mode": {
        "type": "string",
        "required": true,
        "enum": ["single", "multiple"],
        "description": "Determines whether campaign offers one product or multiple products for selection"
      },
      "market": {
        "type": "string",
        "required": true,
        "enum": ["ko", "ja", "en"],
        "description": "Target market language code determining i18n resource file"
      },
      "hero_image_url": {
        "type": "string (URI)",
        "required": true,
        "max_length": 2048,
        "description": "Campaign hero/banner image URL (http/https only)"
      },
      "introduction_text": {
        "type": "string",
        "required": true,
        "max_length": 2000,
        "description": "Campaign introduction/description text"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["draft", "published"],
        "description": "Campaign publication status; must have products assigned before publishing"
      },
      "created_at": {
        "type": "string",
        "required": true,
        "format": "ISO 8601 UTC (e.g. 2025-01-15T09:00:00Z)",
        "description": "Campaign creation timestamp"
      },
      "updated_at": {
        "type": "string",
        "required": true,
        "format": "ISO 8601 UTC (e.g. 2025-01-15T09:00:00Z)",
        "description": "Last update timestamp"
      },
      "products": {
        "type": "array of CampaignProduct",
        "required": true,
        "constraints": "1 item for single mode, 1-50 items for multiple mode",
        "description": "Products assigned to this campaign with optional per-campaign overrides"
      },
      "ugc_gallery": {
        "type": "array of UGCPost",
        "required": true,
        "constraints": "0-20 items",
        "description": "Curated UGC posts displayed on campaign page"
      }
    },
    "campaign_product_constraints": {
      "product_id": { "type": "string", "required": true, "description": "References product_id in Product Library" },
      "product_name": { "type": "string", "required": true, "max_length": 200 },
      "product_image_url": { "type": "string (URI)", "required": true, "max_length": 2048, "scheme": "http|https" },
      "short_description": { "type": "string", "required": true, "max_length": 500 },
      "product_detail_url": { "type": "string | null", "required": false, "max_length": 2048, "scheme": "http|https" },
      "size_guide_url": { "type": "string | null", "required": false, "max_length": 2048, "scheme": "http|https" },
      "available_sizes": { "type": "string[]", "required": true, "min_items": 1, "max_items": 20 },
      "available_colors": { "type": "string[]", "required": true, "min_items": 1, "max_items": 30 },
      "status": { "type": "string", "required": true, "enum": ["open", "closed"] },
      "display_order": { "type": "integer", "required": true, "min": 1, "max": 50 },
      "override_product_image_url": { "type": "string | null", "description": "Overrides library product_image_url when non-null" },
      "override_product_detail_url": { "type": "string | null", "description": "Overrides library product_detail_url when non-null" },
      "override_size_guide_url": { "type": "string | null", "description": "Overrides library size_guide_url when non-null" },
      "override_short_description": { "type": "string | null", "max_length": 500, "description": "Overrides library short_description when non-null" }
    },
    "ugc_post_constraints": {
      "post_id": { "type": "string", "required": true, "format": "UUID v4" },
      "image_url": { "type": "string (URI)", "required": true, "max_length": 2048, "scheme": "http|https" },
      "source_url": { "type": "string | null", "required": false, "format": "Instagram post URL (https://www.instagram.com/p/...)" },
      "display_order": { "type": "integer", "required": true, "min": 1, "max": 20 }
    },
    "override_resolution": "For fields with override support, resolved_value = override_value if override_value is not null, else product_library_default_value"
  },
