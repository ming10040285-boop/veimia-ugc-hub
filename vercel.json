{
  "version": 2,
  "functions": {
    "api/register.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/admin/campaigns.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/admin/products.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/admin/campaign_products.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/admin/upload.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/admin/ugc.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/admin/registrations.py": { "runtime": "@vercel/python", "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
