{
  "version": 2,
  "builds": [
    { "src": "api/register.py", "use": "@vercel/python" },
    { "src": "api/admin/campaigns.py", "use": "@vercel/python" },
    { "src": "api/admin/products.py", "use": "@vercel/python" },
    { "src": "api/admin/campaign_products.py", "use": "@vercel/python" },
    { "src": "api/admin/upload.py", "use": "@vercel/python" },
    { "src": "api/admin/ugc.py", "use": "@vercel/python" },
    { "src": "api/admin/registrations.py", "use": "@vercel/python" },
    { "src": "api/admin/save.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/admin/save", "dest": "/api/admin/save.py" },
    { "src": "/api/admin/campaigns/(.*)", "dest": "/api/admin/campaigns.py" },
    { "src": "/api/admin/campaigns", "dest": "/api/admin/campaigns.py" },
    { "src": "/api/admin/products/(.*)", "dest": "/api/admin/products.py" },
    { "src": "/api/admin/products", "dest": "/api/admin/products.py" },
    { "src": "/api/admin/campaign_products", "dest": "/api/admin/campaign_products.py" },
    { "src": "/api/admin/upload", "dest": "/api/admin/upload.py" },
    { "src": "/api/admin/ugc", "dest": "/api/admin/ugc.py" },
    { "src": "/api/admin/registrations", "dest": "/api/admin/registrations.py" },
    { "src": "/api/register", "dest": "/api/register.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
