# ============================================================
# VEIMIA UGC Brand Collaboration Hub - Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# For Vercel deployment, set these in the Vercel Dashboard
# under Settings > Environment Variables.
#
# IMPORTANT: Never commit actual credentials to version control.
# ============================================================

# --- Google Sheets Integration (Required) ---
# JSON string of the Google Cloud service account credentials.
# Obtain from Google Cloud Console > IAM & Admin > Service Accounts.
# Create a key (JSON format), then paste the entire JSON content here as a single line.
# Example: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SHEETS_CREDENTIALS=

# The Google Sheets spreadsheet ID where registration data will be stored.
# Found in the spreadsheet URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEETS_ID=

# --- Image Storage (Choose one) ---
# Option A: Vercel Blob (Recommended for Vercel deployments)
# Obtain from Vercel Dashboard > Storage > Blob > Token
BLOB_READ_WRITE_TOKEN=

# Option B: Cloudinary (Free tier alternative)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Obtain from Cloudinary Dashboard > Account Details
CLOUDINARY_URL=

# --- Optional Configuration ---
# Custom domain for the deployment (if not using default xxx.vercel.app)
# CUSTOM_DOMAIN=ugc.veimia.com

# Base URL override for local development
# BASE_URL=http://localhost:3000
